# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# S3 Buckets
RAW_BUCKET=your-raw-data-bucket
STAGING_BUCKET=your-staging-bucket
CURATED_BUCKET=your-curated-data-bucket

# IAM Role ARNs
LAMBDA_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/LambdaExecutionRole
GLUE_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/GlueCrawlerRole

# API Ingestion
REST_URL=https://api.example.com/data
API_KEY=your_api_key_here

# Kinesis
KINESIS_STREAM_NAME=your-kinesis-stream

# FTP
FTP_HOST=ftp.example.com
FTP_USER=your_ftp_user
FTP_PASSWORD=your_ftp_password
FTP_PATH=/data/

# SNS Alerts
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:pipeline-alerts

# Glue
GLUE_DATABASE=your_glue_database
GLUE_CRAWLER=your_glue_crawler
